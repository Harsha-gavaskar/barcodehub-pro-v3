# BarcodeHub Pro - Environment Configuration
# Copy this to .env and fill in your values

# ── Django Core ────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production-abc123
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (PostgreSQL) ──────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=barcodehub
DB_USER=barcodehub_user
DB_PASSWORD=barcodehub_pass
DB_HOST=localhost
DB_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Google OAuth / Sheets ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# ── AWS S3 ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=barcodehub-pro-storage
AWS_S3_REGION_NAME=us-east-1

# ── Email (SendGrid) ───────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@barcodehub.pro

# ── SMS (Twilio) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ── Frontend ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
